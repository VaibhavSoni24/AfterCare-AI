# AfterCare AI — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ──────────────────────────── Firebase ─────────────────────────────────────
# Frontend (exposed via Vite — safe to include browser-side)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# ──────────────────────────── Backend API URL ──────────────────────────────
# Points the frontend to the FastAPI backend (Cloud Run URL or localhost)
VITE_API_BASE_URL=http://localhost:8000

# ──────────────────────────── Backend (Server-Side Only) ───────────────────
# Gemini 1.5 Flash API Key (Google AI Studio — never expose to browser)
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin SDK — path to service account JSON file
# Download from Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase-service-account.json

# Firebase Project ID (same as above)
FIREBASE_PROJECT_ID=your_firebase_project_id

# Firebase Storage Bucket (same as above)
FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# ──────────────────────────── Google Cloud ─────────────────────────────────
# GCP Project ID (for Cloud Tasks, Cloud Run)
GCP_PROJECT_ID=your_gcp_project_id

# Cloud Tasks queue name for medication reminders
CLOUD_TASKS_QUEUE_NAME=medication-reminders

# Cloud Run service base URL (for Cloud Tasks HTTP targets)
CLOUD_RUN_SERVICE_URL=https://aftercare-ai-backend-xxxx-ew.a.run.app

# ──────────────────────────── Google Calendar ──────────────────────────────
# Google Calendar service account credentials JSON (escaped or path)
# Required for server-side Calendar event creation
GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ──────────────────────────── CORS ─────────────────────────────────────────
# Allowed frontend origin for CORS (Firebase Hosting URL or localhost)
FRONTEND_URL=http://localhost:5173
